<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="Trauma Team Database"
                      MinSize="500 400">
    <BoxContainer Orientation="Vertical">
        
        <BoxContainer Orientation="Horizontal" MinHeight="30" Margin="0 0 0 10">
            <Label Text="Имя клиента" HorizontalExpand="True" ClipText="True"/>
            <Label Text="Состояние" MinWidth="100"/>
            <Label Text="Пакет услуг" MinWidth="120"/>
        </BoxContainer>
        
        <controls:HLine Color="#404040" Thickness="2" Margin="0 5"/>

        <ScrollContainer VerticalExpand="True">
            <BoxContainer Name="PatientList" Orientation="Vertical"/>
        </ScrollContainer>
        
    </BoxContainer>
</controls:FancyWindow>